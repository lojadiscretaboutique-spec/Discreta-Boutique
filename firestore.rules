rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isMasterAdmin() {
      return signedIn() && (
        request.auth.uid == "VpnA7EDoSoUMF0VGOHyiCjyrOSf2" ||
        (
          "email" in request.auth.token && 
          request.auth.token.email == "lojadiscretaboutique@gmail.com"
        )
      );
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function can(moduleName, action) {
      return isMasterAdmin() || (
        signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        getUserData().status != 'bloqueado' &&
        (
          getUserData().role == 'admin' || 
          (
            "computedPermissions" in getUserData() && 
            getUserData().computedPermissions is map && 
            moduleName in getUserData().computedPermissions &&
            action in getUserData().computedPermissions[moduleName] &&
            getUserData().computedPermissions[moduleName][action] == true
          ) ||
          (
            "permissions" in getUserData() && 
            getUserData().permissions is map && 
            moduleName in getUserData().permissions &&
            getUserData().permissions[moduleName] == true
          ) // Legacy fallback
        )
      );
    }

    match /users/{uid} {
      allow read: if request.auth.uid == uid || can('users', 'visualizar');
      allow create: if can('users', 'criar');
      allow update: if request.auth.uid == uid || can('users', 'editar');
      allow delete: if can('users', 'excluir');
    }

    match /roles/{doc} {
      allow read: if signedIn();
      allow create: if can('roles', 'criar');
      allow update: if can('roles', 'editar');
      allow delete: if can('roles', 'excluir');
    }

    match /products/{doc} {
      allow read: if true; // Public for storefront
      allow create: if can('produtos', 'criar');
      allow update: if can('produtos', 'editar') || can('orders', 'criar') || can('orders', 'editar') || can('orders', 'excluir') || 
        (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['stock', 'updatedAt'])
        );
      allow delete: if can('produtos', 'excluir');
    }

    match /products/{productId}/variants/{variantId} {
      allow read: if true; 
      allow create: if can('produtos', 'criar');
      allow update: if can('produtos', 'editar') || can('orders', 'criar') || can('orders', 'editar') || can('orders', 'excluir') || 
        (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['stock', 'updatedAt'])
        );
      allow delete: if can('produtos', 'excluir');
    }

    // Explicit collectionGroup rule for global variant search
    match /{path=**}/variants/{variantId} {
      allow read: if true; 
    }

    match /stockMovements/{doc} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if can('stock', 'excluir') || can('orders', 'editar') || can('orders', 'excluir');
    }

    match /categories/{doc} {
      allow read: if true;
      allow create: if can('categorias', 'criar');
      allow update: if can('categorias', 'editar') || (
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['accessCount', 'updatedAt'])
      );
      allow delete: if can('categorias', 'excluir');
    }

    match /banners/{doc} {
      allow read: if true;
      allow create: if can('banners', 'criar');
      allow update: if can('banners', 'editar');
      allow delete: if can('banners', 'excluir');
    }

    match /home_section_settings/{doc} {
      allow read: if true;
      allow create, update: if can('banners', 'editar') || isMasterAdmin();
      allow delete: if can('banners', 'excluir') || isMasterAdmin();
    }

    match /home_section_layouts/{doc} {
      allow read: if true;
      allow create, update: if can('banners', 'editar') || isMasterAdmin();
      allow delete: if can('banners', 'excluir') || isMasterAdmin();
    }

    match /home_section_schedules/{doc} {
      allow read: if true;
      allow create, update: if can('banners', 'editar') || isMasterAdmin();
      allow delete: if can('banners', 'excluir') || isMasterAdmin();
    }

    match /home_custom_sections/{doc} {
      allow read: if true;
      allow create, update: if can('banners', 'editar') || isMasterAdmin();
      allow delete: if can('banners', 'excluir') || isMasterAdmin();
    }

    match /home_section_order/{doc} {
      allow read: if true;
      allow create, update: if can('banners', 'editar') || isMasterAdmin();
      allow delete: if can('banners', 'excluir') || isMasterAdmin();
    }

    match /offer_banners/{doc} {
      allow read: if true;
      allow create, update: if isMasterAdmin() || can('banners', 'criar');
      allow delete: if can('banners', 'excluir');
    }

    match /settings/instagram_brand_kit {
      allow read, create, update: if true;
    }

    match /settings/{doc} {
      allow read: if true;
      allow update: if can('settings', 'editar');
      allow create: if can('settings', 'criar');
    }

    match /themes/{doc} {
      allow read: if true;
      allow create: if can('settings', 'criar');
      allow update: if can('settings', 'editar');
      allow delete: if can('settings', 'excluir') || can('settings', 'editar');
    }

    match /auditLogs/{doc} {
      allow read: if can('logs', 'visualizar');
      allow create: if true;
      allow update, delete: if false;
    }

    match /orders/{doc} {
      allow create: if true;
      allow read: if true;
      allow update: if true;
      allow delete: if can('orders', 'excluir');
    }

    match /customers/{doc} {
      allow create, get, update: if true;
      allow list: if can('clientes', 'visualizar');
      allow delete: if can('clientes', 'excluir');
    }

    match /visitor_sessions/{doc} {
      allow create, get, update: if true;
      allow list, delete: if can('dashboard', 'visualizar');
    }

    match /page_views/{doc} {
      allow create: if true;
      allow read, update, delete: if can('dashboard', 'visualizar');
    }

    match /visitor_analytics/{doc} {
      allow read, write: if can('dashboard', 'visualizar');
    }

    match /states/{doc} {
      allow read: if true;
      allow create: if can('areasEntrega', 'criar');
      allow update: if can('areasEntrega', 'editar');
      allow delete: if can('areasEntrega', 'excluir');
    }

    match /cities/{doc} {
      allow read: if true;
      allow create: if can('areasEntrega', 'criar');
      allow update: if can('areasEntrega', 'editar');
      allow delete: if can('areasEntrega', 'excluir');
    }

    match /deliveryAreas/{doc} {
      allow read: if true;
      allow create: if can('areasEntrega', 'criar');
      allow update: if can('areasEntrega', 'editar');
      allow delete: if can('areasEntrega', 'excluir');
    }

    match /cashSessions/{doc} {
      allow read: if can('caixa', 'visualizar');
      allow create: if can('caixa', 'criar');
      allow update: if can('caixa', 'editar');
      allow delete: if can('caixa', 'excluir');
    }

    match /cashTransactions/{doc} {
      allow read: if can('caixa', 'visualizar') || can('orders', 'editar') || can('orders', 'excluir');
      allow create: if can('caixa', 'criar') || can('orders', 'criar');
      allow update, delete: if can('caixa', 'excluir') || can('orders', 'editar') || can('orders', 'excluir');
    }

    match /financial_transactions/{doc} {
      allow read: if can('financeiro', 'visualizar') || can('orders', 'editar') || can('orders', 'excluir');
      allow create: if can('financeiro', 'criar') || can('orders', 'criar');
      allow update: if can('financeiro', 'editar');
      allow delete: if can('financeiro', 'excluir') || can('orders', 'editar') || can('orders', 'excluir');
    }

    match /purchases/{doc} {
      allow read: if can('compras', 'visualizar');
      allow create: if can('compras', 'criar');
      allow update: if can('compras', 'editar');
      allow delete: if can('compras', 'excluir');
    }

    match /search_logs/{doc} {
      allow create: if true; 
      allow read: if isMasterAdmin() || can('dashboard', 'visualizar') || can('logs', 'visualizar');
    }

    match /intelligent_searches/{doc} {
      allow read, create, update, delete: if true;
      match /engagements/{eng} {
        allow read, create, update, delete: if true;
      }
    }

    match /buscas_inteligentes/{doc} {
      allow read, create, update, delete: if true;
    }

    match /ai_curation/{doc} {
      allow read: if true;
      allow write: if isMasterAdmin() || can('dashboard', 'editar');
    }

    match /webhook_logs/{doc} {
      allow read: if can('logs', 'visualizar');
      allow create: if true;
      allow update, delete: if false;
    }

    match /ai_query_cache/{doc} {
      allow read, create, update: if true;
      allow delete: if false;
    }

    match /abandoned_carts/{doc} {
      allow read, create, update: if true; 
      allow delete: if can('logs', 'excluir');
    }

    match /recovery_logs/{doc} {
      allow read: if can('logs', 'visualizar');
      allow create: if true; // Allowed for server background job
      allow update, delete: if false;
    }

    match /combos/{doc} {
      allow read: if true;
      allow create: if can('produtos', 'criar');
      allow update: if can('produtos', 'editar') || can('orders', 'criar') || can('orders', 'editar');
      allow delete: if can('produtos', 'excluir');
    }

    match /coupons/{doc} {
      allow read: if true;
      allow create: if can('banners', 'criar');
      allow update: if can('banners', 'editar') || can('orders', 'criar');
      allow delete: if can('banners', 'excluir');
    }

    match /promotions/{doc} {
      allow read: if true;
      allow create: if can('banners', 'criar');
      allow update: if can('banners', 'editar');
      allow delete: if can('banners', 'excluir');
    }

    match /popups/{doc} {
      allow read: if true;
      allow create: if can('banners', 'criar');
      allow update: if can('banners', 'editar') || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clickCount'])
      );
      allow delete: if can('banners', 'excluir');
    }

    match /instagram_posts/{doc} {
      allow read, create, update: if true;
      allow delete: if isMasterAdmin();
    }

    match /instagram_logs/{doc} {
      allow read, create: if true;
      allow update, delete: if isMasterAdmin();
    }

    match /instagram_integracoes/{doc} {
      allow read, create, update: if true;
      allow delete: if isMasterAdmin();
    }

    match /instagram_brand_kits/{doc} {
      allow read, create, update: if true;
      allow delete: if isMasterAdmin();
    }

    match /instagram_brandkit_data/{doc} {
      allow read, create, update: if true;
      allow delete: if isMasterAdmin();
    }

    match /instagram_brand_kit_configs/{doc} {
      allow read, create, update: if true;
      allow delete: if isMasterAdmin();
    }

    match /affiliates/{doc} {
      allow get: if true;
      allow list: if can('banners', 'visualizar') || isMasterAdmin() || (signedIn() && resource.data.uid == request.auth.uid);
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if can('banners', 'editar') || isMasterAdmin() || 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clicks'])) || 
        (signedIn() && resource.data.uid == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pixKey', 'pixType', 'whatsapp']));
      allow delete: if can('banners', 'excluir') || isMasterAdmin();
    }

    match /marketing_calendar/{doc} {
      allow read, write: if true;
    }

    match /mkt_campaigns/{doc} {
      allow read, write: if true;
    }

    match /mkt_tasks/{doc} {
      allow read, write: if true;
    }

    match /mkt_influencers/{doc} {
      allow read, write: if true;
    }

    match /mkt_affiliates/{doc} {
      allow read, write: if true;
    }

    match /mkt_promotions/{doc} {
      allow read, write: if true;
    }

    match /mkt_giveaways/{doc} {
      allow read, write: if true;
    }

    match /mkt_content/{doc} {
      allow read, write: if true;
    }

    match /mkt_alerts/{doc} {
      allow read, write: if true;
    }

    match /mkt_whatsapp/{doc} {
      allow read, write: if true;
    }

    match /lives/{doc} {
      allow read: if true;
      allow create: if can('banners', 'criar') || isMasterAdmin();
      allow update: if can('banners', 'editar') || isMasterAdmin() || true; // Public updates allowed to increment views/clicks/conversions
      allow delete: if can('banners', 'excluir') || isMasterAdmin();
    }

    match /wifiLeads/{doc} {
      allow read, write: if true;
    }

    match /public_home_cache/{doc} {
      allow read: if true;
      allow write: if isMasterAdmin() || can('banners', 'editar') || can('banners', 'criar');
    }

    match /public_catalog_cache/{doc} {
      allow read: if true;
      allow write: if isMasterAdmin() || can('banners', 'editar') || can('banners', 'criar');
    }

    match /blog_posts/{doc} {
      allow read: if true;
      allow create: if isMasterAdmin() || can('marketing', 'criar');
      allow update: if isMasterAdmin() || can('marketing', 'editar') || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views'])
      );
      allow delete: if isMasterAdmin() || can('marketing', 'excluir');
    }

    match /blog_categories/{doc} {
      allow read: if true;
      allow create, update: if isMasterAdmin() || can('marketing', 'editar');
      allow delete: if isMasterAdmin() || can('marketing', 'excluir');
    }

    match /blog_tags/{doc} {
      allow read: if true;
      allow create, update: if isMasterAdmin() || can('marketing', 'editar');
      allow delete: if isMasterAdmin() || can('marketing', 'excluir');
    }

    match /blog_comments/{doc} {
      allow read: if true;
      allow create: if true; // Public comments
      allow update, delete: if isMasterAdmin() || can('marketing', 'editar');
    }

    match /blog_settings/{doc} {
      allow read: if true;
      allow write: if isMasterAdmin() || can('marketing', 'editar');
    }

    match /blog_authors/{doc} {
      allow read: if true;
      allow write: if isMasterAdmin() || can('marketing', 'editar');
    }

    match /blog_statistics/{doc} {
      allow read: if isMasterAdmin() || can('marketing', 'visualizar');
      allow create, update: if true; // Captures clicks and shares anonymously
      allow delete: if isMasterAdmin() || can('marketing', 'excluir');
    }

    match /blog_clusters/{doc} {
      allow read, list: if true;
      allow create, update: if isMasterAdmin() || can('marketing', 'editar');
      allow delete: if isMasterAdmin() || can('marketing', 'excluir');
    }

    match /blog_ai_generations/{doc} {
      allow read, write: if isMasterAdmin() || can('marketing', 'editar') || can('marketing', 'visualizar');
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

