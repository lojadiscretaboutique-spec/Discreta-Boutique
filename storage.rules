rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if signedIn();
    }

    match /categories/{allPaths=**} {
      allow read: if true;
      allow write: if signedIn();
    }

    match /banners/{allPaths=**} {
      allow read: if true;
      allow write: if signedIn();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
